# Template for local dev .env. Copy to `.env` (gitignored) and fill in values.

# --- Auth ---
JWT_SECRET=
JWT_TTL_SECONDS=3600

# --- CoinGecko (public API works without a key) ---
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_TIMEOUT_MS=10000
COINGECKO_MAX_RETRIES=3

# --- CryptoCompare ---
CRYPTOCOMPARE_API_KEY=
CRYPTOCOMPARE_BASE_URL=https://min-api.cryptocompare.com
CRYPTOCOMPARE_TIMEOUT_MS=15000

# --- Etherscan V2 (multi-chain) ---
# Get a key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api
ETHERSCAN_TIMEOUT_MS=10000
ETHERSCAN_CONCURRENCY=5

# --- Background prefetchers (off by default in dev) ---
# ENABLE_PREFETCHERS=true
# YEARLY_PREFETCH_TOP=200
# PCT_PREFETCH_TOP=200
