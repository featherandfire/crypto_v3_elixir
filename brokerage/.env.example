# Template for local dev .env. Copy to `.env` (gitignored) and fill in values.

# --- Auth ---
JWT_SECRET=
JWT_TTL_SECONDS=3600

# --- Alpaca Broker API (Broke 2 Brokerage partner credentials) ---
# Apply at https://alpaca.markets/broker. Sandbox creds available before
# full live approval. Used for customer KYC, account funding (ACH/wire/
# instant), and money movement. Different from the Trading API key —
# leave the trading vars in place for paper-trading order flow.
B2B_API_KEY=
B2B_API_SECRET=
# https://broker-api.sandbox.alpaca.markets for sandbox,
# https://broker-api.alpaca.markets for live.
B2B_BROKER_BASE_URL=https://broker-api.sandbox.alpaca.markets
# Shared secret for Alpaca webhook HMAC verification. Set this to match
# the secret Alpaca shows when you register the webhook URL in their
# dashboard. Leave blank to disable the webhook receiver (returns 503).
ALPACA_WEBHOOK_SECRET=
